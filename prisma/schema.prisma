generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model Product {
  id                 Int      @id @default(autoincrement())
  productName        String
  productDescription String
  productImagePath   String
  avaibility         String
  category           String
  createdAt          DateTime @default(now())
}

model Review {
  id        String   @id @default(uuid())
  name      String
  message   String
  createdAt DateTime @default(now())
  replyTo   String?
  parent    Review?  @relation("ReviewReply", fields: [replyTo], references: [id])
  replies   Review[] @relation("ReviewReply")
}
